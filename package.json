{
  "name": "zulipbot",
  "version": "1.0.0",
  "description": "GitHub workflow-optimizing bot",
  "type": "module",
  "scripts": {
    "start": "node ./src/index.ts",
    "pretest": "tsc && eslint && prettier --check .",
    "test:node": "env NODE_ENV=test node --test --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=lcov.info",
    "test": "node --run test:node"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620",
  "dependencies": {
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/request-error": "^7.1.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "express": "^5.2.1",
    "lodash": "^4.18.1",
    "ts-extras": "^1.0.0"
  },
  "devDependencies": {
    "@octokit/openapi-types": "^27.0.0",
    "@octokit/openapi-webhooks-types": "^12.1.0",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.19.21",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-xo": "^0.53.1",
    "nock": "^14.0.15",
    "partial-mock": "^1.1.0",
    "prettier": "^3.8.4",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/zulip/zulipbot.git"
  },
  "keywords": [
    "zulip",
    "bot",
    "bots",
    "github",
    "workflow",
    "zulipbot",
    "synicalsyntax"
  ],
  "author": "Cynthia Lin <cynthialin1004@gmail.com> (https://synicalsyntax.com)",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/zulip/zulipbot/issues"
  },
  "homepage": "https://github.com/zulip/zulipbot#readme"
}
