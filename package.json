  "author": "Cynthia Lin <cynthialin1004@gmail.com> (https://synicalsyntax.com)",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/zulip/zulipbot/issues"
  },
  "homepage": "https://github.com/zulip/zulipbot#readme",
  "tap": {
    "allow-incomplete-coverage": true,
    "test-env": [
      "NODE_ENV=test"
    ]
  }
