{
  "name": "zulipbot",
  "version": "1.0.0",
  "description": "GitHub workflow-optimizing bot",
  "type": "module",
  "scripts": {
    "start": "node ./src/index.ts",
    "pretest": "tsc && eslint . && prettier --check . '!**/*.js' '!**/*.ts'",
    "test": "tap --coverage-report=lcovonly"
  },
  "packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4",
  "dependencies": {
    "@octokit/plugin-retry": "^8.0.3",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/request-error": "^7.1.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "express": "^5.2.1",
    "lodash": "^4.18.1",
    "ts-extras": "^0.17.0"
  },
  "devDependencies": {
    "@octokit/openapi-types": "^27.0.0",
    "@octokit/openapi-webhooks-types": "^12.1.0",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.23",
    "@types/node": "^22.19.7",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-xo": "^0.50.0",
    "eslint-config-xo-typescript": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^63.0.0",
    "nock": "^14.0.10",
    "partial-mock": "^1.1.0",
    "prettier": "~3.5.3",
    "tap": "^21.5.0",
    "type-fest": "^5.4.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "repository": {
